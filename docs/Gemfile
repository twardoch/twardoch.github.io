# frozen_string_literal: true

source "https://rubygems.org"

# Match what GitHub Pages runs in production so local previews match the
# deployed site. › https://pages.github.com/versions/
gem "github-pages", group: :jekyll_plugins

# `github-pages` already pulls in jekyll-remote-theme, jekyll-seo-tag and
# jekyll-sitemap, so the theme defined as `remote_theme:` in _config.yml
# (just-the-docs/just-the-docs) loads without extra gem declarations here.

# Windows + JRuby don't include zoneinfo files; add the tzinfo data gem.
platforms :windows, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

# Performance booster for watching directories on Windows.
gem "wdm", "~> 0.2.0", :platforms => [:windows]
